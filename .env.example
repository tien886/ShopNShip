# Copy this file to .env and edit values as needed.
# docker-compose automatically loads variables from a file named .env
# in the same directory. .env.example itself is NOT read by docker-compose.

# Shared HMAC secret used by auth-service to sign JWTs and by order-service +
# delivery-service to verify them. MUST be identical across all three services.
JWT_SECRET=shopnship-dev-secret-change-me
